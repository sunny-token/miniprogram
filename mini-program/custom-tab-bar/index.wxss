.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 9999;
  transition: all 0.4s ease;
  /* Glassmorphism effect */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.tab-bar.dark {
  background: rgba(26, 28, 28, 0.95);
  border-top: 1rpx solid rgba(255,255,255,0.05);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.icon-container {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  /* Blend mode hack to merge white background into parent background */
  mix-blend-mode: multiply;
  transition: all 0.3s;
}

.dark .tab-icon {
  /* In dark mode, invert might be needed if icons are dark on white */
  filter: invert(0.9) hue-rotate(180deg);
  mix-blend-mode: initial;
}

.tab-text {
  font-size: 20rpx;
  color: #94A3B8;
  transition: color 0.3s;
}

.tab-text.selected {
  color: #43655A;
  font-weight: 600;
}

.dark .tab-text.selected {
  color: #8fb3a6;
}

/* CSS Icons for TabBar */
.icon-draw {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  border: 4rpx solid #94A3B8;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.selected .icon-draw {
  border-color: currentColor;
}

/* Specific Icons using CSS Drawing */
/* Placeholder style - using masks for now but setting colors strictly */
.icon-mask {
  width: 44rpx;
  height: 44rpx;
  background-color: #94A3B8;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

.icon-mask.selected {
  background-color: #43655A;
}

.dark .icon-mask.selected {
  background-color: #8fb3a6;
}
