page {
  --primary: #43655a;
  --primary-container: #8fb3a6;
  --tertiary: #7d562d;
  --tertiary-container: #d3a272;
  --surface: #f9f9f9;
  --surface-container: #eeeeee;
  --on-surface: #1a1c1c;
  --on-surface-variant: #414845;
  --outline-variant: #c1c8c4;
}

.dark {
  --primary: #8fb3a6;
  --primary-container: #43655a;
  --surface: #1a1c1c;
  --surface-container: #2c2e2e;
  --on-surface: #f9f9f9;
  --on-surface-variant: #c1c8c4;
  --outline-variant: #414845;
}

page {
  background-color: var(--surface);
  color: var(--on-surface);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  line-height: 1.5;
  font-size: 28rpx;
  transition: background-color 0.4s ease, color 0.4s ease;
}

.container {
  padding: 32rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  min-height: 100vh;
}

.card {
  background: var(--surface-card, #ffffff);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(193, 200, 196, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.dark .card {
  --surface-card: var(--surface-container);
  border-color: rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.2);
}

.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }

.circular-progress {
  transform: rotate(-90deg);
}

.btn-primary {
  background-color: var(--primary);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(67, 101, 90, 0.2);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
