.wallpaper-container {
  width: 100vw;
  height: 100vh;
  background-color: #1a1c1c;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.wallpaper-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  height: 100rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.streak-badge {
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
}

.level-badge {
  margin-left: auto;
  background: #8fb3a6;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  opacity: 0.9;
}

.wallpaper-swiper {
  flex: 1;
  width: 100%;
}

.wallpaper-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.wallpaper-image {
  width: 100%;
  height: 100%;
}

/* Watermark Styles (Spec 2.2) */
.watermark-overlay {
  position: absolute;
  bottom: 300rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.watermark-text {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(4rpx);
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
  padding: 10rpx 40rpx;
  border-radius: 50rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.style-badge {
  position: absolute;
  top: 15vh;
  right: -20rpx;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  padding: 10rpx 40rpx 10rpx 30rpx;
  border-radius: 50rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  transform: rotate(90deg);
  transform-origin: right center;
}

.action-bar {
  position: absolute;
  bottom: 120rpx;
  left: 40rpx;
  right: 40rpx;
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: 20rpx;
  z-index: 90;
}

.action-btn {
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 36rpx;
  padding: 24rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.2);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.action-btn.active {
  background: #fff;
  color: #1a1c1c;
}

.action-btn.active .btn-text {
  opacity: 1;
}

.btn-icon {
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.btn-text {
  font-size: 18rpx;
  font-weight: normal;
  opacity: 0.8;
}

.lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(30px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.lock-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,1);
  padding: 60rpx 80rpx;
  border-radius: 50rpx;
}

.lock-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.lock-text {
  font-size: 28rpx;
  color: #1a1c1c;
  font-weight: 800;
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

.lock-btn {
  background: #43655a;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.bottom-hint {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: rgba(255,255,255,0.3);
  font-size: 18rpx;
  letter-spacing: 4rpx;
  pointer-events: none;
}
