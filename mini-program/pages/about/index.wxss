/* pages/about/index.wxss */
.container {
  padding: 40rpx;
  background-color: var(--surface);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.about-hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.logo-container {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-container);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(67, 101, 90, 0.2);
  margin-bottom: 40rpx;
}

.logo-inner {
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid #ffffff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
}

.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.app-tagline {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.6;
  font-style: italic;
  margin-bottom: 16rpx;
}

.app-version {
  font-size: 20rpx;
  color: var(--outline-variant);
  letter-spacing: 2rpx;
  margin-bottom: 32rpx;
}

.theme-toggle {
  background: var(--surface-container);
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--primary);
  border: 1rpx solid rgba(143, 179, 166, 0.2);
}

.theme-toggle:active {
  opacity: 0.7;
}

.info-sections {
  margin-top: 60rpx;
}

.section {
  margin-bottom: 60rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary);
  display: block;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid var(--primary-container);
}

.section-content {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  line-height: 1.8;
  display: block;
  opacity: 0.8;
}

.feature-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.feature-item {
  background: var(--surface-container);
  padding: 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(193, 200, 196, 0.1);
}

.feature-name {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--primary);
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: var(--on-surface-variant);
  line-height: 1.4;
  display: block;
  opacity: 0.6;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--surface-container);
  padding: 30rpx;
  border-radius: 24rpx;
  margin-bottom: 12rpx;
}

.setting-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.setting-desc {
  font-size: 20rpx;
  color: var(--on-surface-variant);
  opacity: 0.5;
  display: block;
  padding: 0 10rpx;
}

.footer {
  margin-top: 80rpx;
  margin-bottom: calc(140rpx + env(safe-area-inset-bottom));
  padding-bottom: 40rpx;
  text-align: center;
  border-top: 1rpx solid var(--outline-variant);
  padding-top: 40rpx;
  opacity: 0.4;
}

.footer text {
  display: block;
  font-size: 20rpx;
  color: var(--on-surface-variant);
  margin-bottom: 8rpx;
}
