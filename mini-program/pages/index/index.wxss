.container {
  display: flex;
  flex-direction: column;
  padding: 32rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: var(--surface);
}

/* Header Section */
.header-section {
  padding-top: 20rpx;
  margin-bottom: 40rpx;
}

.picker-row {
  display: flex;
  margin: 0 -12rpx;
}

.picker-btn {
  flex: 1;
  background: var(--surface-container);
  padding: 24rpx 28rpx;
  border-radius: 32rpx;
  margin: 0 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(67, 101, 90, 0.05);
  border: 1rpx solid rgba(67, 101, 90, 0.08);
}

.picker-content {
  display: flex;
  flex-direction: column;
}

.picker-label {
  font-size: 20rpx;
  color: var(--on-surface-variant);
  opacity: 0.5;
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}

.picker-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

/* Progress Section */
.progress-section {
  position: relative;
  background: var(--surface-container);
  border-radius: 64rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(67, 101, 90, 0.08);
  margin-bottom: 40rpx;
}

.mode-toggle {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 80rpx;
  height: 80rpx;
  background: var(--surface-container);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: all 0.3s ease;
}

.mode-toggle:active {
  transform: scale(0.9);
  background: rgba(143, 179, 166, 0.2);
}

.mode-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.6;
}

.progress-visual {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin-bottom: 60rpx;
}

.visual-container {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Circle View */
.circle-visual {
  position: relative;
  width: 440rpx;
  height: 440rpx;
}

.circle-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 24rpx solid var(--primary-container);
  opacity: 0.1; /* Very light background ring */
  box-sizing: border-box;
}

.circle-active {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  /* Using mask to create a precise 24rpx ring */
  -webkit-mask: radial-gradient(transparent 196rpx, #000 197rpx);
  mask: radial-gradient(transparent 196rpx, #000 197rpx);
}

/* Grid View */
.grid-visual {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 12rpx;
  width: 400rpx;
}

.grid-dot {
  aspect-ratio: 1;
  background: var(--surface-container);
  border-radius: 6rpx;
  transition: all 0.5s ease;
}

.grid-dot.active {
  background: var(--primary-container);
  box-shadow: 0 0 12rpx var(--primary-container);
}

/* Rings View */
.rings-visual {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-track {
  position: absolute;
  border: 4rpx solid var(--surface-container);
  border-radius: 50%;
  opacity: 0.3;
}

.ring-active {
  position: absolute;
  background: var(--primary-container);
  border-radius: 50%;
  opacity: 0.6;
  box-shadow: 0 0 40rpx rgba(143, 179, 166, 0.4);
}

/* Common Progress Text */
.progress-content {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 5;
}

.completed-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 6rpx;
  opacity: 0.4;
  margin-bottom: 4rpx;
}

.number-row {
  display: flex;
  align-items: baseline;
}

.main-number {
  font-size: 100rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.1;
}

.percent-symbol {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary-container);
  margin-left: 4rpx;
}

.status-desc {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.6;
  margin-top: 4rpx;
}

/* Stats Display */
.stats-display {
  width: 100%;
  text-align: center;
}

.stats-main {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on-surface-variant);
  margin-bottom: 24rpx;
}

.stats-main .highlight {
  color: var(--primary);
  font-size: 36rpx;
}

.countdown-pill {
  display: inline-flex;
  background: var(--surface-container);
  padding: 14rpx 36rpx;
  border-radius: 100rpx;
}

.pill-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
  font-family: 'SF Pro Text', -apple-system, system-ui, sans-serif;
}

/* Quote Section */
.quote-section {
  padding: 20rpx 0;
}

.quote-card-inner {
  background: var(--surface-container);
  padding: 60rpx 48rpx;
  border-radius: 48rpx;
  border: 1rpx solid var(--outline-variant);
  opacity: 0.9;
  position: relative;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.02);
}

.quote-content {
  font-size: 34rpx;
  line-height: 1.6;
  color: var(--on-surface);
  font-style: italic;
  font-weight: 500;
}

.quote-hint {
  font-size: 20rpx;
  color: var(--on-surface-variant);
  margin-top: 32rpx;
  opacity: 0.5;
  letter-spacing: 2rpx;
}

.quote-mark {
  position: absolute;
  font-size: 80rpx;
  color: var(--primary-container);
  opacity: 0.15;
  font-family: serif;
}

.quote-mark.left { top: 20rpx; left: 30rpx; }
.quote-mark.right { bottom: -20rpx; right: 30rpx; }

/* Action Footer */
.action-footer {
  margin-top: auto;
  padding: 40rpx 0 80rpx;
}

.btn-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-generate {
  width: 100% !important;
  height: 110rpx;
  background: var(--primary);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 40rpx rgba(67, 101, 90, 0.2);
  border: none;
}

.btn-generate:active {
  transform: translateY(2rpx);
  box-shadow: 0 10rpx 20rpx rgba(67, 101, 90, 0.2);
}

.action-hint {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.6;
  margin-top: 24rpx;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  width: 100%;
}

/* Modal and Poster */
.modal {
  position: fixed;
  inset: 0;
  z-index: 10000;
  visibility: hidden;
  opacity: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  padding: 40rpx;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.modal-container {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  display: flex;
  flex-direction: column;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform: translateY(100rpx);
}

.modal.show .modal-container {
  transform: translateY(0);
}

.poster-preview {
  background: var(--surface-container);
  border-radius: 56rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  transition: background-color 0.4s ease;
}

.poster-preview.style-minimal {
  background-color: #ffffff;
}

.poster-preview.style-grey {
  background-color: #f5f7f6;
}

.poster-preview.style-green {
  background-color: #e8f0ed;
}

.poster-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.bureau-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.bureau-subtitle {
  font-size: 18rpx;
  color: var(--on-surface-variant);
  letter-spacing: 2rpx;
  opacity: 0.5;
}

.poster-visual {
  width: 360rpx;
  height: 360rpx;
  margin: 40rpx 0;
  border-radius: 50%;
  border: 12rpx solid var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-val {
  font-size: 80rpx;
  font-weight: 800;
  color: var(--primary);
}

.poster-label {
  font-size: 18rpx;
  color: var(--on-surface-variant);
  letter-spacing: 4rpx;
}

.poster-footer {
  text-align: center;
}

.poster-quote {
  font-size: 30rpx;
  line-height: 1.5;
  color: var(--on-surface);
  margin-bottom: 32rpx;
  display: block;
}

.poster-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--on-surface-variant);
  opacity: 0.5;
}

.meta-dot {
  width: 6rpx;
  height: 6rpx;
  background: currentColor;
  border-radius: 50%;
  margin: 0 16rpx;
}

.modal-controls {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 0 10rpx;
}

.style-toggle, .ad-unlock {
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.15);
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 32rpx;
}

.btn-primary, .btn-secondary {
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #ffffff;
}

.btn-secondary {
  background: var(--surface);
  color: var(--on-surface);
}

.btn-close {
  position: absolute;
  top: -80rpx;
  right: 0;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* Interactive Section */
.interactive-section {
  margin-top: 40rpx;
}

.sign-card {
  background: var(--surface-container);
  border-radius: 32rpx;
  padding: 40rpx;
  transition: all 0.3s ease;
  position: relative;
  border: 1rpx solid var(--outline-variant);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.sign-card.signed {
  border-bottom: 8rpx solid var(--primary-container);
}

.sign-inner {
  display: flex;
  align-items: center;
}

.sign-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 32rpx;
  opacity: 0.8;
}

.sign-info {
  flex: 1;
}

.sign-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--on-surface);
  display: block;
  margin-bottom: 8rpx;
}

.sign-desc {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.7;
}

.sign-action {
  background: var(--primary);
  color: #ffffff;
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.sign-action.secondary {
  background: var(--primary);
  opacity: 1;
  box-shadow: 0 4rpx 12rpx rgba(67, 101, 90, 0.2);
}

.sign-action:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* Summary Poster Styles Addon */
.summary-date {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 10rpx;
}

.summary-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  padding: 40rpx 0;
}

.stat-box {
  background: rgba(143, 179, 166, 0.05);
  padding: 30rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-lab {
  font-size: 20rpx;
  color: #94A3B8;
  letter-spacing: 2rpx;
}

.ritual-banner {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 48rpx;
  padding: 32rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  flex-direction: column;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.04);
  transform: translateY(-20rpx);
  opacity: 0;
  transition: all 0.7s cubic-bezier(0.2, 0, 0, 1);
  margin-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

.ritual-banner.show {
  transform: translateY(0);
  opacity: 1;
}

.dark .ritual-banner {
  background: rgba(44, 46, 46, 0.8);
  border-color: rgba(255, 255, 255, 0.05);
}

.ritual-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ritual-subtitle {
  font-size: 20rpx;
  color: var(--primary);
  font-weight: 800;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  opacity: 0.6;
}

.ritual-close {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.4;
}

.ritual-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.ritual-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.ritual-greeting {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--on-surface);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.ritual-quote {
  font-size: 26rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
  opacity: 0.8;
}

.ritual-action {
  width: 88rpx;
  height: 88rpx;
  background: var(--primary);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(67, 101, 90, 0.2);
  margin-left: 32rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.ritual-action-single {
  font-size: 36rpx;
  font-weight: 800;
}

.ritual-action:active {
  transform: scale(0.9);
}

@keyframes mini-breathe {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.sign-icon-css {
  width: 80rpx;
  height: 80rpx;
  margin-right: 32rpx;
  background: var(--primary-container);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.sign-icon-css.breathing {
  animation: breathing 2s ease-in-out infinite;
}

@keyframes breathing {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.red-dot {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  width: 18rpx;
  height: 18rpx;
  background: #FF5252;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  z-index: 5;
}

.dark .red-dot {
  border-color: var(--surface-container);
}

.sign-card.should-remind {
  border: 1rpx solid rgba(67, 101, 90, 0.3);
  box-shadow: 0 8rpx 20rpx rgba(67, 101, 90, 0.1);
}

.sign-icon-css::after {
  content: '签';
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 800;
}

.signed .sign-icon-css {
  background: var(--primary);
}

.signed .sign-icon-css::after {
  content: '✓';
  color: #ffffff;
}

/* Dark Mode Extra */
.dark .stat-box {
  background: rgba(255, 255, 255, 0.03);
}

/* AI Wallpaper Card Styles */
.wallpaper-card {
  background: var(--surface-container);
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(193, 200, 196, 0.1);
  margin-top: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-sizing: border-box;
}

.wallpaper-card:active {
  transform: scale(0.98);
  background: rgba(143, 179, 166, 0.05);
}

.wallpaper-preview {
  width: 140rpx;
  height: 180rpx;
  border-radius: 20rpx;
  background-size: cover;
  background-position: center;
  background-color: var(--primary-container);
  background-image: linear-gradient(135deg, var(--primary-container) 0%, var(--primary) 100%);
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.streak-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4rpx);
  color: #ffffff;
  font-size: 16rpx;
  padding: 4rpx 12rpx;
  border-bottom-right-radius: 12rpx;
}

.checkin-status {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--primary);
  color: #ffffff;
  font-size: 18rpx;
  text-align: center;
  padding: 8rpx 0;
  font-weight: bold;
  opacity: 0.9;
}

.checkin-status.done {
  background: rgba(0, 0, 0, 0.3);
}

.wallpaper-info {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.wallpaper-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--primary);
}

.level-tag {
  background: var(--primary-container);
  color: #ffffff;
  font-size: 16rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: bold;
}

.wallpaper-desc {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.8;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-arrow {
  color: var(--primary);
  font-size: 32rpx;
  font-weight: bold;
  opacity: 0.3;
  margin-left: 10rpx;
}
